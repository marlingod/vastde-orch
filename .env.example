# VAST Management Service
VMS_ADDRESS=vms.example.com
VMS_TOKEN=
# Or username/password instead of token:
# VMS_USER=admin
# VMS_PASSWORD=

# Container registry credentials (referenced from vastde.yaml)
REGISTRY_USER=
REGISTRY_PASSWORD=

# Kubernetes
KUBECONFIG=~/.kube/config

# Optional: per-pipeline S3 creds referenced from vastde.yaml secrets
S3_KEY=
S3_SECRET=
